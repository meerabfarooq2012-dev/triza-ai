DATABASE_URL=file:/home/z/my-project/db/custom.db

# =============================================================================
# Payment Gateway Configuration
# =============================================================================

# Payment Gateway Mode: sandbox (for testing) or live (real payments)
PAYMENT_GATEWAY_MODE=sandbox

# Base URL for payment callbacks (webhook URLs)
# In production, set this to your public domain (e.g., https://marketo.pk)
PAYMENT_CALLBACK_BASE_URL=http://localhost:3000

# =============================================================================
# Easypaisa Business API Credentials
# Get these from: Easypaisa Business Portal or call 3737
# Docs: https://easypaisa.com.pk/business-solutions
# =============================================================================
EASYPAISA_MERCHANT_ID=
EASYPAISA_STORE_ID=
EASYPAISA_API_KEY=
EASYPAISA_API_URL=https://easypaisa-api.easypaisa.com.pk

# =============================================================================
# JazzCash Merchant API Credentials
# Get these from: JazzCash Merchant Portal or call 4444
# Docs: https://www.jazzcash.com.pk/business
# =============================================================================
JAZZCASH_MERCHANT_ID=
JAZZCASH_PASSWORD=
JAZZCASH_INTEGRITY_SALT=
JAZZCASH_API_URL=https://api.jazzcash.com.pk
