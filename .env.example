# =============================================================================
# Thiora - Environment Variables Template
# =============================================================================
# Copy this file to .env.local and fill in the values
# For Vercel deployment, add these in Project Settings > Environment Variables

# ── DATABASE (Required) ────────────────────────────────────────────────────
# Supabase PostgreSQL connection string (with pgbouncer for Vercel)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true
# Direct connection for Prisma migrations (without pgbouncer)
DIRECT_URL=postgresql://postgres:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

# ── AUTH & SECURITY ────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-this
CSRF_SECRET=your-csrf-secret-key-change-this

# ── SUPABASE STORAGE ───────────────────────────────────────────────────────
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# ── GOOGLE OAUTH (Optional) ────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id

# ── EMAIL (Resend) ─────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxx

# ── PAYMENT GATEWAYS (Optional - sandbox defaults available) ───────────────
EASYPAISA_MERCHANT_ID=
EASYPAISA_STORE_ID=
EASYPAISA_API_KEY=
EASYPAISA_API_URL=
JAZZCASH_MERCHANT_ID=
JAZZCASH_PASSWORD=
JAZZCASH_INTEGRITY_SALT=
JAZZCASH_API_URL=
PAYMENT_GATEWAY_MODE=sandbox
PAYMENT_CALLBACK_BASE_URL=https://your-domain.vercel.app

# ── AI (Optional) ──────────────────────────────────────────────────────────
COHERE_API_KEY=
GEMINI_API_KEY=

# ── URLs ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_PLATFORM_URL=https://your-domain.vercel.app
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app
NEXT_PUBLIC_BASE_URL=https://your-domain.vercel.app

# ── SOCKET (Auto-detected on Vercel - no config needed) ────────────────────
# Real-time features gracefully degrade to REST polling on Vercel
# NEXT_PUBLIC_SOCKET_DISABLED=true  # Uncomment to force-disable sockets
