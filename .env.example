# ============================================
# Marketo Platform - Environment Variables
# ============================================
# Copy this file to .env and fill in the values

# --- Database ---
# SQLite for development, PostgreSQL for production
DATABASE_URL="file:./db/custom.db"

# --- Authentication ---
# REQUIRED: JWT secret for signing tokens (MUST be changed in production)
JWT_SECRET="change-me-to-a-random-64-char-string"
# REQUIRED: CSRF protection secret (must be different from JWT_SECRET)
CSRF_SECRET="change-me-to-another-random-64-char-string"
# Admin setup key for initial admin creation
ADMIN_SETUP_KEY="change-me-to-a-random-string"

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_JWT_SECRET="your-supabase-jwt-secret"

# --- Email (Resend) ---
RESEND_API_KEY="re_your-api-key"
EMAIL_FROM="noreply@yourdomain.com"

# --- Storage ---
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET="marketplace"

# --- Payment Gateways ---
PAYMENT_GATEWAY_MODE="sandbox"
EASYPAISA_MERCHANT_ID=""
EASYPAISA_PASSWORD=""
EASYPAISA_HASH_KEY=""
JAZZCASH_MERCHANT_ID=""
JAZZCASH_PASSWORD=""
JAZZCASH_INTEGRITY_SALT=""
PAYONEER_API_KEY=""
WISE_API_KEY=""

# --- Shipping Carriers ---
TCS_API_KEY=""
TCS_CUSTOMER_CODE=""
LEOPARDS_API_KEY=""
LEOPARDS_API_PASSWORD=""

# --- AI ---
GOOGLE_GENERATIVE_AI_API_KEY=""

# --- OAuth ---
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- URLs ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
FRONTEND_URL="http://localhost:3000"

# --- Rate Limiting ---
TRUSTED_PROXY_COUNT="1"

# --- Node Environment ---
NODE_ENV="development"
